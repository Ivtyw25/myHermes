# Hermes Dashboard — environment variables
# Local dev: copy to .env.local. Production: inject via systemd EnvironmentFile.

# Public base URL of the site.
NEXTAUTH_URL=http://localhost:3000

# Session signing secret. Generate: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32

# Absolute path to the directory containing yyyy-mm.csv files.
HERMES_DATA_PATH=/home/user/finance

# bcrypt hash of your password. Generate:
#   node -e "console.log(require('bcryptjs').hashSync('yourpassword',12))"
#
# GOTCHA (.env.local only): Next's env loader runs dotenv-expand, which treats
# "$" as a variable reference and will MANGLE a bcrypt hash ($2b$12$...).
# In .env.local you MUST escape each "$" as "\$", e.g.:
#   HERMES_PASSWORD_HASH=\$2b\$12\$abcdef...
# Production systemd EnvironmentFile does NOT expand — use the RAW hash there.
HERMES_PASSWORD_HASH=\$2b\$12\$replace-with-your-own-bcrypt-hash
