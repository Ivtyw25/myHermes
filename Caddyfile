# Hermes Dashboard — Caddy reverse proxy with rate limiting.
#
# Rate limiting needs the caddy-ratelimit module (not in stock Caddy). Build it:
#   go install github.com/caddyserver/xcaddy/cmd/xcaddy@latest
#   ~/go/bin/xcaddy build --with github.com/mholt/caddy-ratelimit
#   sudo mv caddy /usr/local/bin/caddy && caddy version
#
# Replace YOUR_VPS_IP with your actual static IP, then:  caddy start --config Caddyfile
# tls internal generates a self-signed cert — browser will warn on first visit,
# click Advanced → Proceed. HTTPS is active and traffic is encrypted.

{
	# caddy-ratelimit is a third-party directive; tell Caddy where it sits.
	order rate_limit before reverse_proxy
}

https://YOUR_VPS_IP {
	tls internal

	encode zstd gzip

	header {
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		# ponytail: no HSTS — self-signed cert + HSTS causes browser lockout
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'"
		-Server
	}

	# Throttle auth endpoints: max 5 requests per IP per minute -> 6th gets HTTP 429.
	@auth path /api/auth/*
	rate_limit @auth {
		zone auth_zone {
			key {remote_host}
			events 5
			window 1m
		}
	}

	reverse_proxy localhost:3000
}
